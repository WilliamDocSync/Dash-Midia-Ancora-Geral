                    <h3 class="font-black text-slate-800 uppercase text-sm">Desempenho Consolidado</h3>
                    <select id="v1_grouping" class="border rounded p-1.5 text-xs bg-white font-bold shadow-sm" onchange="renderMasterTable()">
                        <option value="frente">Agrupar por Frente</option><option value="canal">Agrupar por Canal</option>
                    </select>
                </div>
                <div class="overflow-x-auto">
                    <table class="min-w-full text-left text-sm border-collapse whitespace-nowrap">
