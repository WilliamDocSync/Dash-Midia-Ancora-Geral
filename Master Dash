                    <h3 class="font-black text-slate-800 uppercase text-sm">Desempenho Micro</h3>
                    <select id="v2_grouping" class="border rounded p-1.5 text-xs font-bold shadow-sm" onchange="renderAnaliseTable()"><option value="ad">Por Anúncio</option><option value="adset">Por Conjunto</option><option value="campaign">Por Campanha</option><option value="demo">Por Demográfico</option></select>
                </div>
                <div class="overflow-x-auto custom-scrollbar">
