        // ==========================================
        // V1: MASTER LOGIC
        // ==========================================
        let v1_dataA=[], v1_dataB=[];
        function renderMaster() {
            let p1s=document.getElementById('v1_p1Start').value, p1e=document.getElementById('v1_p1End').value;
            let p2s=document.getElementById('v1_p2Start').value, p2e=document.getElementById('v1_p2End').value;
            let plat=document.getElementById('v1_platform').value;
            let fil = (d,s,e) => d.Data>=s && d.Data<=e && (plat==='ALL' || d.Plataforma===plat || d.Plataforma==='Todas');
            v1_dataA = window.globalData.filter(d=>fil(d,p1s,p1e)); v1_dataB = window.globalData.filter(d=>fil(d,p2s,p2e));
            
            let agg = (data) => data.reduce((a,c)=>{ a.g+=c.Gasto; a.l+=c.Leads; a.gp+=c.GastoPlan; a.lp+=c.LeadsPlan; a.v+=c.Vendas; a.vp+=c.VendasPlan; return a;}, {g:0,l:0,gp:0,lp:0,v:0,vp:0});
            let aA = agg(v1_dataA), aB = agg(v1_dataB);
            
            const card = (l, va, vb, plan, mon, inv) => {
                let pct = vb>0 ? ((va-vb)/vb)*100 : 0; let c = (inv ? pct<=0 : pct>=0) ? 'delta-up text-green-500' : 'delta-down text-red-500';
                return `<div class="bg-white p-4 border rounded shadow-sm">
                    <div class="text-[10px] font-bold text-slate-500 uppercase flex justify-between">${l} <span class="${c}">${pct>=0?'▲':'▼'} ${Math.abs(pct).toFixed(1)}%</span></div>
                    <div class="text-2xl font-black my-1">${mon?fmt.m(va):fmt.n(va)}</div>
                    <div class="text-[10px] text-slate-400 font-bold">Meta: ${mon?fmt.m(plan):fmt.n(plan)}</div>
                </div>`;
            };
            document.getElementById('v1_kpiContainer').innerHTML = card("Investimento", aA.g, aB.g, aA.gp, true) + card("Leads", aA.l, aB.l, aA.lp, false) + card("CPL Médio", aA.l>0?aA.g/aA.l:0, aB.l>0?aB.g/aB.l:0, aA.lp>0?aA.gp/aA.lp:0, true, true) + card("Vendas", aA.v, aB.v, aA.vp, false) + card("CPA Médio", aA.v>0?aA.g/aA.v:0, aB.v>0?aB.g/aB.v:0, aA.vp>0?aA.gp/aA.vp:0, true, true);
            
            renderMasterChart(); renderMasterTable();
        }
        function renderMasterTable() {
            let dim = document.getElementById('v1_grouping').value === 'frente' ? 'Frente' : 'Plataforma';
            let g = v1_dataA.filter(d=>d.Plataforma!=='Todas').reduce((a,c)=>{ if(!a[c[dim]]) a[c[dim]]={n:c[dim], g:0,i:0,cl:0,l:0,v:0}; a[c[dim]].g+=c.Gasto; a[c[dim]].i+=c.Impressoes; a[c[dim]].cl+=c.Cliques; a[c[dim]].l+=c.Leads; a[c[dim]].v+=c.Vendas; return a;}, {});
            document.getElementById('v1_tableBody').innerHTML = Object.values(g).sort((a,b)=>b.g-a.g).map(i=>`<tr class="hover:bg-slate-50"><td class="px-4 py-2 font-bold">${i.n}</td><td class="px-4 py-2 text-right">${fmt.m(i.g)}</td><td class="px-4 py-2 text-right">${fmt.n(i.i)}</td><td class="px-4 py-2 text-right">${fmt.p(i.i>0?(i.cl/i.i)*100:0)}</td><td class="px-4 py-2 text-right text-blue-700 font-bold">${fmt.n(i.l)}</td><td class="px-4 py-2 text-right">${fmt.p(i.cl>0?(i.l/i.cl)*100:0)}</td><td class="px-4 py-2 text-right text-orange-600 font-bold">${fmt.m(i.l>0?i.g/i.l:0)}</td><td class="px-4 py-2 text-right text-green-700 font-bold">${fmt.n(i.v)}</td><td class="px-4 py-2 text-right">${fmt.m(i.v>0?i.g/i.v:0)}</td></tr>`).join('');
        }
        function renderMasterChart() {
            let m = document.getElementById('v1_metric').value, dim = document.getElementById('v1_dimension').value === 'frente' ? 'Frente' : 'Plataforma';
            let dates = [...new Set([...v1_dataA, ...v1_dataB].map(d=>d.Data))].sort();
            let dims = [...new Set([...v1_dataA, ...v1_dataB].filter(d=>d.Plataforma!=='Todas').map(d=>d[dim]))].filter(Boolean);
            let ds = dims.map((dn, i) => {
                let color = ['#3b82f6','#10b981','#f97316','#8b5cf6','#ef4444'][i%5];
                return { label: dn, borderColor: color, tension:0.3, data: dates.map(dt => {
                    let rows = [...v1_dataA, ...v1_dataB].filter(r=>r.Data===dt && r[dim]===dn);
                    let tg=0, tl=0, tv=0; rows.forEach(r=>{tg+=r.Gasto; tl+=r.Leads; tv+=r.Vendas;});
                    if(m==='cpl') return tl>0?tg/tl:0; if(m==='cpa') return tv>0?tg/tv:0; if(m==='gasto') return tg; return tl;
                })};
            });
            if(v1_ChartObj) v1_ChartObj.destroy();
            v1_ChartObj = new Chart(document.getElementById('v1_chart'), { type: 'line', data: {labels:dates, datasets:ds}, options: { plugins:{datalabels:{display:false}} }});
        }

        // ==========================================
        // V2: ANÁLISE MICRO LOGIC
        // ==========================================
        let v2_dataA=[];
        function renderAnalise() {
            let p1s=document.getElementById('v2_p1Start').value, p1e=document.getElementById('v2_p1End').value;
            let fre=document.getElementById('v2_frente').value, cam=document.getElementById('v2_campanha').value, txt=document.getElementById('v2_busca').value.toLowerCase();
            v2_dataA = window.globalData.filter(d=> d.Data>=p1s && d.Data<=p1e && d.Plataforma!=='Todas' && (fre==='ALL'||d.Frente===fre) && (cam==='ALL'||d.Campanha===cam) && (!txt||d.Anuncio.toLowerCase().includes(txt)));
            
            let sc = arr => { let m=Math.max(...arr.map(i=>i.leads),1), c=Math.min(...arr.filter(i=>i.cpl>0).map(i=>i.cpl),100); arr.forEach(i=>{ i.score=i.leads>0?Math.round(((i.leads/m)*40+(c/Math.max(i.cpl,0.1))*40+(i.cvr/100)*20)):0;}); return arr.sort((a,b)=>b.score-a.score);};
            let a = (f) => Object.values(v2_dataA.reduce((ac,d)=>{let k=d[f]; if(!ac[k]) ac[k]={n:k,g:0,l:0,i:0,cl:0, th:d.ImageURL}; ac[k].g+=d.Gasto; ac[k].l+=d.Leads; ac[k].i+=d.Impressoes; ac[k].cl+=d.Cliques; return ac;},{})).map(i=>{i.cpl=i.l>0?i.g/i.l:0; i.cvr=i.cl>0?(i.l/i.cl)*100:0; i.leads=i.l; return i;});
            
            let rnk = (id, data) => document.getElementById(id).innerHTML = sc(data).slice(0,3).map(i=>`<tr><td class="p-2 truncate max-w-[100px] font-bold">${i.n}</td><td class="p-2 text-right text-blue-600 font-bold">${i.l}</td><td class="p-2 text-right text-orange-600">${fmt.m(i.cpl)}</td></tr>`).join('');
            rnk('v2_topCam', a('Campanha')); rnk('v2_topAdset', a('Conjunto')); rnk('v2_topDemo', a('Demografico').filter(i=>i.n!=='N/A'));
            
            let ads = sc(a('Anuncio')).slice(0,10);
            document.getElementById('v2_topAds').innerHTML = ads.map(i=>`<tr><td class="p-2 text-[10px] font-bold truncate max-w-[150px]"><img src="${i.th}" class="w-6 h-6 inline mr-1 rounded bg-slate-200 object-cover">${i.n}</td><td class="p-2 text-right">${fmt.m(i.g)}</td><td class="p-2 text-right text-blue-600 font-bold">${i.l}</td><td class="p-2 text-right text-orange-600">${fmt.m(i.cpl)}</td><td class="p-2 text-center font-black">${i.score}</td></tr>`).join('');
            
            if(v2_ChartObj) v2_ChartObj.destroy();
            v2_ChartObj = new Chart(document.getElementById('v2_chart'), { type: 'bar', data: { labels: ads.slice(0,5).map(i=>i.n.substring(0,10)), datasets: [{ label: 'Leads', data: ads.map(i=>i.l), backgroundColor: '#8b5cf6', yAxisID: 'y' }, { label: 'CPL', data: ads.map(i=>i.cpl), type: 'line', borderColor: '#f97316', yAxisID: 'y1' }] }, options: { scales: { y1: { position: 'right' } } } });
            renderAnaliseTable();
        }
        function renderAnaliseTable() {
            let g = document.getElementById('v2_grouping').value;
            let f = g==='ad'?'Anuncio':g==='adset'?'Conjunto':g==='campaign'?'Campanha':'Demografico';
            let a = Object.values(v2_dataA.reduce((ac,d)=>{let k=d[f]; if(!ac[k]) ac[k]={n:k,g:0,l:0,i:0,cl:0}; ac[k].g+=d.Gasto; ac[k].l+=d.Leads; ac[k].i+=d.Impressoes; ac[k].cl+=d.Cliques; return ac;},{})).map(i=>{i.cpl=i.l>0?i.g/i.l:0; i.cvr=i.cl>0?(i.l/i.cl)*100:0; i.leads=i.l; return i;});
            let m=Math.max(...a.map(i=>i.leads),1), c=Math.min(...a.filter(i=>i.cpl>0).map(i=>i.cpl),100); a.forEach(i=>{ i.score=i.leads>0?Math.round(((i.leads/m)*40+(c/Math.max(i.cpl,0.1))*40+(i.cvr/100)*20)):0;});
            document.getElementById('v2_tableBody').innerHTML = a.sort((x,y)=>y.score-x.score).map(i=>`<tr class="hover:bg-slate-50"><td class="px-4 py-2 font-bold">${i.n}</td><td class="px-4 py-2 text-right">${fmt.m(i.g)}</td><td class="px-4 py-2 text-right">${fmt.n(i.i)}</td><td class="px-4 py-2 text-right">${fmt.p(i.i>0?(i.cl/i.i)*100:0)}</td><td class="px-4 py-2 text-right font-black text-blue-600">${fmt.n(i.l)}</td><td class="px-4 py-2 text-right">${fmt.p(i.cvr)}</td><td class="px-4 py-2 text-right text-orange-600">${fmt.m(i.cpl)}</td><td class="px-4 py-2 text-center font-black">${i.score}</td></tr>`).join('');
        }

        // ==========================================
        // V3: PACING LOGIC
        // ==========================================
        function renderPacing() {
            let mo = document.getElementById('v3_month').value;
            let dAtual = 15; // Set to actual `new Date().getDate()` in prod
            let dTot = new Date(parseInt(mo.split('-')[0]), parseInt(mo.split('-')[1]), 0).getDate();
            let dRest = Math.max(dTot - dAtual, 1);
            document.getElementById('v3_lblCorridos').innerText = dAtual; document.getElementById('v3_lblRestantes').innerText = dRest;
            renderPacingTable(mo, dAtual, dTot, dRest);
        }
        function renderPacingTable(mo, dA, dT, dR) {
            let grp = document.getElementById('v3_grouping').value; // Frente, Plataforma, Conta
            let b = window.globalData.reduce((ac, d) => {
                if(!d.Data.startsWith(mo)) return ac;
                let k = d[grp]; if(!ac[k]) ac[k]={n:k,g:0,go:0,gp:0, l:0,lo:0,lp:0, v:0,vo:0,vp:0};
                if(d.Plataforma !== 'Todas') { ac[k].g+=d.Gasto; ac[k].l+=d.Leads; ac[k].v+=d.Vendas; }
                if(d.Plataforma === 'Todas') { ac[k].gp+=d.GastoPlan; ac[k].lp+=d.LeadsPlan; ac[k].vp+=d.VendasPlan; }
                // Simulating Yesterday logic. In prod check if d.Data === ontem
                return ac;
            },{});
            
            let arr = Object.values(b);
            document.getElementById('v3_tableBody').innerHTML = arr.map(d=>{
                let pG=(d.g/dA)*dT, pL=(d.l/dA)*dT, pV=(d.v/dA)*dT;
                return `<tr class="hover:bg-slate-50 border-b"><td class="px-4 py-3 font-bold border-r">${d.n}</td><td class="px-4 py-3 text-right">${fmt.m(d.g)}</td><td class="px-4 py-3 text-right text-orange-500">-</td><td class="px-4 py-3 text-right ${pG>d.gp?'text-red-500':'text-emerald-500'}">${fmt.m(pG)}</td><td class="px-4 py-3 text-right font-bold bg-slate-50">${fmt.m(d.gp)}</td><td class="px-4 py-3 text-right font-black border-r text-emerald-600 bg-emerald-50">${fmt.m(Math.max((d.gp-d.g)/dR,0))}</td><td class="px-4 py-3 text-right text-blue-600">${fmt.n(d.l)}</td><td class="px-4 py-3 text-right text-orange-500">-</td><td class="px-4 py-3 text-right ${pL<d.lp?'text-red-500':'text-blue-500'}">${fmt.n(pL)}</td><td class="px-4 py-3 text-right font-bold bg-slate-50">${fmt.n(d.lp)}</td><td class="px-4 py-3 text-right font-black border-r text-blue-600 bg-blue-50">${fmt.n(Math.max((d.lp-d.l)/dR,0))}</td><td class="px-4 py-3 text-right text-green-600">${fmt.n(d.v)}</td><td class="px-4 py-3 text-right text-orange-500">-</td><td class="px-4 py-3 text-right">${fmt.n(pV)}</td><td class="px-4 py-3 text-right font-bold bg-slate-50">${fmt.n(d.vp)}</td><td class="px-4 py-3 text-right font-black text-green-600 bg-green-50">${fmt.n(Math.max((d.vp-d.v)/dR,0))}</td></tr>`;
            }).join('');
            
            let tot = arr.reduce((a,c)=>{a.g+=c.g; a.gp+=c.gp; a.l+=c.l; a.lp+=c.lp; a.v+=c.v; a.vp+=c.vp; return a;},{g:0,gp:0,l:0,lp:0,v:0,vp:0});
            let c = (t,a,m,mon) => `<div class="bg-white p-4 border rounded shadow-sm"><div class="text-[10px] font-bold text-slate-400 uppercase flex justify-between">${t}<span>Meta: ${mon?fmt.m(m):fmt.n(m)}</span></div><div class="text-2xl font-black">${mon?fmt.m(a):fmt.n(a)}</div><div class="w-full bg-slate-100 h-2 mt-2"><div class="${a>m?'bg-red-500':'bg-emerald-500'} h-2" style="width:${Math.min((a/m)*100||0,100)}%"></div></div></div>`;
            document.getElementById('v3_kpiContainer').innerHTML = c("Investimento",tot.g,tot.gp,true)+c("Leads",tot.l,tot.lp,false)+c("Vendas",tot.v,tot.vp,false);
        }

    </script>
