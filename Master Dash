                        <div class="flex gap-1"><input type="date" id="v2_p1Start" class="w-full rounded p-1 text-xs border-none"><input type="date" id="v2_p1End" class="w-full rounded p-1 text-xs border-none"></div>
                    </div>
                </div>
                <div><label class="text-[10px] font-bold text-slate-500 uppercase block mb-1">Frente</label><select id="v2_frente" class="w-full border rounded p-2 text-xs outline-none bg-slate-50"><option value="ALL">Todas</option></select></div>
                <div><label class="text-[10px] font-bold text-slate-500 uppercase block mb-1">Campanha</label><select id="v2_campanha" class="w-full border rounded p-2 text-xs outline-none bg-slate-50"><option value="ALL">Todas</option></select></div>
                <div><label class="text-[10px] font-bold text-slate-500 uppercase block mb-1">Busca Anúncio</label><input type="text" id="v2_busca" placeholder="Ex: video01" class="w-full border rounded p-2 text-xs bg-slate-50"></div>
