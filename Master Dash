                <div class="overflow-x-auto custom-scrollbar">
                    <table class="min-w-full text-left text-sm border-collapse whitespace-nowrap">
                        <thead>
                            <tr class="bg-slate-100 border-b-2 border-slate-300 text-center">
                                <th class="px-4 py-3 border-r-2 border-slate-300 text-left text-slate-700 font-black uppercase text-xs">Estrutura</th>
                                <th colspan="5" class="px-4 py-3 border-r-2 border-slate-300 text-slate-700 uppercase font-black text-xs">💸 Investimento (R$)</th>
                                <th colspan="5" class="px-4 py-3 border-r-2 border-slate-300 text-blue-700 uppercase font-black text-xs">🎯 Leads</th>
                                <th colspan="5" class="px-4 py-3 text-green-700 uppercase font-black text-xs">🛒 Vendas</th>
                            </tr>
                            <tr class="bg-slate-50 border-b border-slate-200 text-[10px] text-slate-500 uppercase font-bold text-right">
                                <th class="px-4 py-2 border-r-2 border-slate-300 text-left text-[11px]">Nome</th>
                                <th class="px-4 py-2">Realizado</th><th class="px-4 py-2 text-orange-600 bg-orange-50/30">Ontem</th><th class="px-4 py-2">Projetado</th><th class="px-4 py-2 text-slate-700 bg-slate-100">Meta Mês</th><th class="px-4 py-2 border-r-2 border-slate-300 text-emerald-600 bg-emerald-50/50">Objetivo Dia</th>
