                    <div class="overflow-x-auto flex-1"><table class="min-w-full text-left text-xs"><thead class="uppercase text-slate-400 bg-slate-50"><tr><th class="p-2">Anúncio</th><th class="p-2 text-right">Gasto</th><th class="p-2 text-right">Leads</th><th class="p-2 text-right">CPL</th><th class="p-2 text-center">Score</th></tr></thead><tbody id="v2_topAds" class="divide-y"></tbody></table></div>
                </div>
                <div class="bg-white rounded-xl border p-5 flex flex-col min-h-[300px]">
                    <h3 class="font-black text-slate-800 uppercase text-center text-sm border-b pb-3 mb-3">Volume vs Eficiência (Top 5)</h3>
