        window.globalData = []; // Onde TUDO fica armazenado
        let v1_ChartObj = null; let v2_ChartObj = null;
        
        // Utilitários Universais
        const fmt = { m: v => new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(v || 0), n: v => new Intl.NumberFormat('pt-BR').format(Math.round(v || 0)), p: v => (v || 0).toFixed(2) + '%' };
        function parseNum(val) { if (!val) return 0; if (typeof val === 'number') return val; let s = String(val).trim().replace(/[^\d,.-]/g, ''); if (s.includes(',') && s.includes('.')) s = s.replace(/\./g, '').replace(',', '.'); else if (s.includes(',')) s = s.replace(',', '.'); let n = parseFloat(s); return isNaN(n) ? 0 : n; }
        function normData(d) { let s = String(d || '').trim(); if(s.toLowerCase() === 'data' || !s) return null; let b = s.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})/); if (b) return `${b[3]}-${b[2].padStart(2,'0')}-${b[1].padStart(2,'0')}`; let i = s.match(/^(\d{4})-(\d{1,2})-(\d{1,2})/); if (i) return `${i[1]}-${i[2].padStart(2,'0')}-${i[3].padStart(2,'0')}`; return null; }
        function normPlat(n) { let s = String(n || '').toLowerCase(); if (s.includes('tiktok')) return 'TikTok'; if (s.includes('facebook') || s.includes('meta') || s.includes('ig')) return 'Facebook Ads'; if (s.includes('google') || s.includes('youtube')) return 'Google Ads'; return n || 'Desconhecida'; }
        
        function padronizarConta(nomeBruto) {
            if (!nomeBruto) return "Outros";
            let n = String(nomeBruto).toLowerCase();
            if (n.includes("ckb espelho")) return "CKB Espelho";
            if (n.includes("ckb whatsapp")) return "CKB - WhatsApp";
            if (n.includes("ckb google")) return "Âncora | CKB";
            if (n.includes("bajaj google")) return "Ancora | Bajaj";
            return nomeBruto; 
        }

        function extrairFrente(nomeConta) {
            if (!nomeConta) return "Outros";
            let n = String(nomeConta).toLowerCase();
            if (n.includes("ckb")) return "CKB";
            if (n.includes("bajaj")) return "Bajaj";
            if (n.includes("noma")) return "Noma";
            if (n.includes("dafra")) return "Dafra";
            if (n.includes("xcmg")) return "XCMG";
            if (n.includes("shineray")) return "Shineray";
            if (n.includes("carros")) return "Carros";
            if (n.includes("imoveis") || n.includes("imóveis")) return "Imóveis";
            if (n.includes("beijar")) return "Beijar Flor";
            let partes = n.split(/[\s\-\|]+/);
            let primeiraPalavra = partes[0];
            if (primeiraPalavra === 'ancora' || primeiraPalavra === 'âncora') return (partes[1] || 'Ancora').toUpperCase();
            return primeiraPalavra.toUpperCase();
        }

        window.onload = () => { carregarTudo(); };

        async function carregarTudo() {
            const status = document.getElementById('globalStatus');
            try {
                let processadas = 0;
                for (let url of SHEET_URLS) {
                    await new Promise(resolve => {
                        Papa.parse(url, { download: true, header: true, skipEmptyLines: true, complete: (res) => {
                            let keys = Object.keys(res.data[0] || {});
                            if (keys.includes('Planejado Meta') || keys.includes('Leads Planejados')) { parsePlanejados(res.data); }
                            else if (keys.includes('Data') && keys.includes('Meta') && keys.includes('Google') && keys.includes('Tik tok')) { parseVendas(res.data); }
                            else { parsePerformance(res.data); }
                            resolve();
                        }, error: resolve });
                    });
                    processadas++;
                    status.innerHTML = `<div class="loader"></div> (${processadas}/${SHEET_URLS.length}) Planilhas...`;
                }
                status.innerHTML = "✅ Tudo Pronto";
                status.classList.replace('text-orange-400', 'text-green-500');
                if (window.globalData.length > 0) initAllDashboards();
            } catch(e) { status.innerHTML = "❌ Erro ao Carregar"; }
        }

        // --- Extratores Universais ---
        function parsePlanejados(data) {
            let mStr = '04', yStr = '2026'; // Defaulting para teste de planejamento como no Master original
            let daysInMonth = new Date(parseInt(yStr), parseInt(mStr), 0).getDate();
            data.forEach(d => {
                let contaBruta = d.Conta; if (!contaBruta) return;
                let contaPadrao = padronizarConta(contaBruta);
                let g = parseNum(d['Planejado Meta']) + parseNum(d['Planejado Google']) + parseNum(d['Planejado Tik Tok']);
                let cplPlan = parseNum(d['CPL Planejado']);
                let l = cplPlan > 0 ? (g / cplPlan) : parseNum(d['Leads Planejados']);
                
                for(let day=1; day<=daysInMonth; day++) {
                    window.globalData.push({ Data: `${yStr}-${mStr}-${day<10?'0'+day:day}`, Frente: extrairFrente(contaPadrao), Conta: contaPadrao, Plataforma: 'Todas', Campanha: '', Conjunto: '', Anuncio: '', Demografico: 'N/A', Gasto: 0, Leads: 0, Impressoes: 0, Cliques: 0, Vendas: 0, GastoPlan: g/daysInMonth, LeadsPlan: l/daysInMonth, VendasPlan: 0 });
                }
            });
        }
        function parseVendas(data) {
            data.forEach(d => {
                let rDate = normData(d.Data); if(!rDate) return;
                let conta = padronizarConta(d.Conta || d.Frente || 'Desconhecida');
                let frente = extrairFrente(conta);
                let vM = parseNum(d.Meta), vG = parseNum(d.Google), vT = parseNum(d['Tik tok']);
                if (vM>0) window.globalData.push({ Data: rDate, Frente: frente, Conta: conta, Plataforma: 'Facebook Ads', Gasto: 0, Leads: 0, Impressoes: 0, Cliques: 0, Vendas: vM, GastoPlan: 0, LeadsPlan: 0, VendasPlan: 0 });
                if (vG>0) window.globalData.push({ Data: rDate, Frente: frente, Conta: conta, Plataforma: 'Google Ads', Gasto: 0, Leads: 0, Impressoes: 0, Cliques: 0, Vendas: vG, GastoPlan: 0, LeadsPlan: 0, VendasPlan: 0 });
                if (vT>0) window.globalData.push({ Data: rDate, Frente: frente, Conta: conta, Plataforma: 'TikTok', Gasto: 0, Leads: 0, Impressoes: 0, Cliques: 0, Vendas: vT, GastoPlan: 0, LeadsPlan: 0, VendasPlan: 0 });
            });
        }
        function parsePerformance(data) {
            data.forEach(d => {
                let rDate = normData(d.Date || d.Data || d['Date (Segment)'] || d.Day || d['Reporting Starts'] || d['Stat time']); if(!rDate) return;
                let cRaw = d['Account Name'] || d.Account || d.Conta || d['Advertiser Name'] || 'Desconhecida';
                let age = d['Age (Breakdown)'] || d.Age || '', gender = d['Gender (Breakdown)'] || d.Gender || '';
                if(gender.toLowerCase().includes('male') && !gender.toLowerCase().includes('fe')) gender='H'; else if(gender.toLowerCase().includes('fe')) gender='M';
                let leadsVal = parseNum(d['Action Leads'] || d.Leads || d.Lead || d.Results || 0);
                let msgConv = parseNum(d['Action Messaging Conversations Started (Onsite Conversion)'] || 0);
                let leads = leadsVal > 0 ? leadsVal : (parseNum(d.Conversions || 0) + msgConv);
                
                window.globalData.push({
                    Data: rDate, Frente: extrairFrente(cRaw), Conta: padronizarConta(cRaw), Plataforma: normPlat(d.Plataforma || d.Platform || d['Platform Name']),
                    Campanha: d['Campaign Name'] || d.Campaign || 'Sem Campanha', Conjunto: d['Adset Name'] || d['Ad group name'] || 'Sem Conjunto',
                    Anuncio: cleanAdName(d['Ad Name'] || d.Ad), Link: d['Instagram Permalink URL'] || '', ImageURL: d['Image URL'] || d['Thumbnail URL'] || '',
                    Demografico: (age||gender)?`${age} | ${gender}`:'N/A', Gasto: parseNum(d['Spend (Cost, Amount Spent)'] || d.Gasto || d.Cost || d.Spend), Leads: leads,
                    Impressoes: parseNum(d.Impressions || d.Impressoes), Cliques: parseNum(d['Action Link Clicks'] || d.Clicks || d.Cliques),
                    Vendas: parseNum(d.Vendas || 0), GastoPlan: 0, LeadsPlan: 0, VendasPlan: 0
                });
            });
        }

